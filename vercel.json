{
  "version": 2,
  "builds": [
    {
      "src": "api/server-bridge.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/server-bridge.ts"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "api/server-bridge.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server-bridge.ts"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "api/server-bridge.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
